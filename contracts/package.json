{
  "name": "contracts-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "clarigen && clarigen docs",
    "build:docs": "clarigen docs",
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"pnpm run test:report\"",
    "generate-coverage": "pnpm test:report && genhtml -o coverage/html lcov.info",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clarigen/cli": "4.1.5",
    "@clarigen/core": "4.1.5",
    "@clarigen/test": "4.1.5",
    "@stacks/clarinet-sdk": "3.16.0",
    "@stacks/clarinet-sdk-wasm": "3.16.0",
    "@noble/secp256k1": "3.1.0",
    "@scure/base": "2.2.0",
    "@scure/btc-signer": "2.0.1",
    "@stacks/stacking": "7.4.0",
    "@stacks/transactions": "7.4.0",
    "c32check": "2.0.0",
    "chokidar-cli": "3.0.0",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vitest-environment-clarinet": "3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  }
}
